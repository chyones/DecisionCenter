{
	# Non-secret ACME contact. Override by changing this deployment config.
	email admin@elrace.com
}

# Production deploys MUST set PUBLIC_HOSTNAME to a real domain so Caddy can issue
# a TLS cert via ACME. The default ":80" target is kept as a fallback for local
# `make up` and CI smoke runs only — it does NOT serve TLS.
#
# Phase 2D Slice 1: Caddy serves the built frontend SPA from /usr/share/caddy
# (mounted from ./frontend/dist) and proxies backend routes to app:8000.
# The backend does not use an /api prefix, so each route family is listed
# explicitly. Hash-based routing means the SPA fallback (try_files) is safe.
# NOTE: every backend route family the SPA calls MUST be listed here — any path
# not matched below falls through to the SPA and returns index.html. ``/me`` (the
# Slice 2 role-resolution endpoint) belongs in this list for that reason.
http://{$PUBLIC_HOSTNAME:localhost} {
	encode zstd gzip

	# Strip the noisy server header and add baseline security headers.
	# CSP notes: style-src needs 'unsafe-inline' for React inline style props;
	# login.microsoftonline.com appears in connect-src/frame-src/form-action for
	# the MSAL redirect + silent-iframe token flows.
	header {
		-Server
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' https://login.microsoftonline.com; frame-src https://login.microsoftonline.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://login.microsoftonline.com; object-src 'none'"
		Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"
	}

	# Backend API routes — proxied explicitly because the backend does not use
	# an /api prefix and we must not change backend business logic in Slice 1.
	handle /healthz* {
		reverse_proxy app:8000 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}
	# Identity/role-resolution endpoint — the production SPA reads the caller's
	# canonical role from GET /me after Entra login. Must reach the backend.
	handle /me* {
		reverse_proxy app:8000 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}
	handle /reports* {
		reverse_proxy app:8000 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}
	handle /workspace* {
		reverse_proxy app:8000 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}
	handle /upload* {
		reverse_proxy app:8000 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}
	handle /admin* {
		reverse_proxy app:8000 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# Static frontend SPA — served for all other requests.
	# try_files ensures hash-route refresh and direct URL entry work.
	handle {
		root * /usr/share/caddy
		try_files {path} /index.html
		file_server
		# Hashed assets are immutable; cache them aggressively.
		header /assets/* Cache-Control "public, max-age=31536000, immutable"
	}
}

# Plain-HTTP fallback used by local `make up` and healthchecks.
:80 {
	# Backend API routes
	handle /healthz* {
		reverse_proxy app:8000
	}
	handle /me* {
		reverse_proxy app:8000
	}
	handle /reports* {
		reverse_proxy app:8000
	}
	handle /workspace* {
		reverse_proxy app:8000
	}
	handle /upload* {
		reverse_proxy app:8000
	}
	handle /admin* {
		reverse_proxy app:8000
	}

	# Static frontend SPA
	handle {
		root * /usr/share/caddy
		try_files {path} /index.html
		file_server
	}
}
