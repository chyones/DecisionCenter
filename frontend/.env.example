# DecisionCenter frontend environment (Vite). Copy to `.env` for local overrides.
#
# Production auth (Phase 2D Slice 2): set these in the PRODUCTION build to enable
# Microsoft Entra (MSAL) login. Leave blank for local dev / CI — the Vite dev
# server keeps the RoleSwitcher + X-User-Role bypass.

# Backend API base URL. Empty = same origin (served behind Caddy in production).
VITE_API_BASE_URL=

# Entra app registration (production builds only).
VITE_ENTRA_CLIENT_ID=
VITE_ENTRA_TENANT_ID=

# API scope whose access token has audience == VITE_ENTRA_CLIENT_ID.
# Leave blank to default to "api://<client_id>/.default".
VITE_ENTRA_API_SCOPE=
