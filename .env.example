# App
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
PUBLIC_BASE_URL=http://localhost:8000
PUBLIC_HOSTNAME=localhost

# Identity
ENTRA_CLIENT_ID=
ENTRA_TENANT_ID=
ENTRA_CLIENT_SECRET=

# LLM providers
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
COHERE_API_KEY=

# Data stores
POSTGRES_DB=decision_center
POSTGRES_USER=decision_center
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=decisioncenter
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=decision-center

# Connector layer
N8N_BASE_URL=http://n8n:5678
N8N_WEBHOOK_TOKEN=
N8N_TIMEOUT=60
SHAREPOINT_SEARCH_WEBHOOK=/webhook/sharepoint-search
OWNCLOUD_LIST_WEBHOOK=/webhook/owncloud-list
EMAIL_SEARCH_WEBHOOK=/webhook/email-search
ODOO_READ_WEBHOOK=/webhook/odoo-read

# ownCloud service-account credentials (read by n8n only — never sent through the webhook body)
OWNCLOUD_USERNAME=
OWNCLOUD_PASSWORD=

# Odoo read-only API (read by n8n only — never sent through the webhook body)
ODOO_URL=
ODOO_DATABASE=
ODOO_USERNAME=
ODOO_API_KEY=

# Observability and budget
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
DAILY_COST_CAP_USD=12
MONTHLY_COST_TARGET_USD=300
